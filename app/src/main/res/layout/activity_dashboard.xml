<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_warm"
    android:padding="@dimen/space_xl">

    <!-- Top bar: greeting + profile icon -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/dashboard_greeting"
        android:textAppearance="@style/TextAppearance.Deeply.Heading1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnProfile"
        android:layout_marginTop="@dimen/space_xl" />

    <ImageButton
        android:id="@+id/btnProfile"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/bg_avatar_circle"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/profile_title"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="@id/tvGreeting"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvGreeting" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/dashboard_subtitle"
        android:textAppearance="@style/TextAppearance.Deeply.BodySmall"
        android:layout_marginTop="@dimen/space_xs"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start session card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStartSession"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_2xl"
        app:cardBackgroundColor="@color/accent_orange"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_start_title"
                android:textAppearance="@style/TextAppearance.Deeply.Heading2"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_start_body"
                android:textAppearance="@style/TextAppearance.Deeply.BodySmall"
                android:textColor="@color/white"
                android:alpha="0.85"
                android:layout_marginTop="@dimen/space_xs" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartSession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_start_button"
                android:textAppearance="@style/TextAppearance.Deeply.Button"
                android:textColor="@color/accent_orange"
                app:backgroundTint="@color/white"
                app:cornerRadius="@dimen/radius_md"
                android:layout_marginTop="@dimen/space_lg" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- History card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHistory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        app:cardBackgroundColor="@color/surface_elevated"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardStartSession"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/space_lg">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_title"
                    android:textAppearance="@style/TextAppearance.Deeply.Heading2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_history_body"
                    android:textAppearance="@style/TextAppearance.Deeply.Caption"
                    android:layout_marginTop="@dimen/space_xs" />

            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chevron_right"
                android:contentDescription="@string/history_title" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
